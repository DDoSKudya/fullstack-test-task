{
  "name": "file-exchange-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b --noEmit",
    "preview": "vite preview",
    "test": "vitest run --coverage --coverage.reporter=text --coverage.reporter=html --coverage.reporter=clover",
    "test:hook": "vitest run --coverage --coverage.reporter=text --coverage.reportsDirectory=node_modules/.cache/vitest-coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@formkit/auto-animate": "^0.8.2",
    "@heroicons/vue": "^2.2.0",
    "@tanstack/vue-query": "^5.66.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.1",
    "vue-sonner": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.2.7",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^17.6.3",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.2.7",
    "vue-tsc": "^2.2.0"
  }
}
