POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fileexchange
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/fileexchange

REDIS_URL=redis://redis:6379/0

STORAGE_PATH=/data/files
MAX_UPLOAD_MB=50
SCAN_MAX_MB=10

LOG_LEVEL=INFO
LOG_FORMAT=console
DOCS_ENABLED=true
UVICORN_RELOAD=--reload
